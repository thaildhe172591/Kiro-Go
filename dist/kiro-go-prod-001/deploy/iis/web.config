<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="AdminToKiroGo" stopProcessing="true">
          <match url="^admin(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="ClaudeMessagesToKiroGo" stopProcessing="true">
          <match url="^(v1/messages|messages|anthropic/v1/messages)(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="ClaudeCountTokensToKiroGo" stopProcessing="true">
          <match url="^(v1/messages/count_tokens|messages/count_tokens)$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="OpenAIChatToKiroGo" stopProcessing="true">
          <match url="^(v1/chat/completions|chat/completions)$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="OpenAIResponsesToKiroGo" stopProcessing="true">
          <match url="^(v1/responses|responses)(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="ModelsToKiroGo" stopProcessing="true">
          <match url="^(v1/models|models)$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="StatsToKiroGo" stopProcessing="true">
          <match url="^v1/stats$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="HealthToKiroGo" stopProcessing="true">
          <match url="^health$" />
          <action type="Rewrite" url="http://127.0.0.1:9180/{R:0}" appendQueryString="true" logRewrittenUrl="true" />
        </rule>

        <rule name="RootToAdmin" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="/admin" redirectType="Found" />
        </rule>

        <rule name="DenyUnknownPublicRoutes" stopProcessing="true">
          <match url=".*" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>
      </rules>
    </rewrite>

    <proxy enabled="true" preserveHostHeader="true" reverseRewriteHostInResponseHeaders="false" timeout="00:10:00" />

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="no-referrer" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering allowDoubleEscaping="true">
        <requestLimits maxAllowedContentLength="104857600" />
        <hiddenSegments>
          <add segment="data" />
          <add segment="logs" />
          <add segment="releases" />
          <add segment="deploy" />
        </hiddenSegments>
        <fileExtensions allowUnlisted="true">
          <add fileExtension=".config" allowed="false" />
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".ps1" allowed="false" />
          <add fileExtension=".cmd" allowed="false" />
          <add fileExtension=".bat" allowed="false" />
          <add fileExtension=".exe" allowed="false" />
          <add fileExtension=".bak" allowed="false" />
          <add fileExtension=".zip" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <urlCompression doStaticCompression="false" doDynamicCompression="false" />
  </system.webServer>
</configuration>
